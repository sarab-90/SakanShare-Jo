CREATE TABLE preferences (
    pref_id SERIAL PRIMARY KEY,
	userid INT UNIQUE REFERENCES users(userid) ON DELETE CASCADE,
    gender VARCHAR(10) CHECK (gender IN ('male', 'female', 'any')),
    min_age INTEGER,
    max_age INTEGER,
    smoking BOOLEAN DEFAULT false,
    sleep_time VARCHAR(50), 
    cleanliness VARCHAR(50),
	noise_tolerance VARCHAR(20),
	pets_allowed BOOLEAN,
	guest_policy VARCHAR(50),
	additional_notes TEXT,
    budget DECIMAL(10,2),
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
	CHECK (min_age IS NULL OR max_age IS NULL OR min_age <= max_age)
);
select * from preferences

