CREATE TABLE messages (
    message_id SERIAL PRIMARY KEY,
    sender_id INT REFERENCES users(userid) ON DELETE CASCADE,
    receiver_id INT REFERENCES users(userid) ON DELETE CASCADE,
    listing_id INT REFERENCES shared_housing(listing_id) ON DELETE SET NULL,
    message_text TEXT NOT NULL,
    is_read BOOLEAN DEFAULT false,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
	CHECK (sender_id <> receiver_id)
);
select * from messages
ALTER TABLE messages
ADD COLUMN conversation_id INT;

CREATE TABLE reviews (
    review_id SERIAL PRIMARY KEY,
    reviewer_id INT REFERENCES users(userid) ON DELETE CASCADE,
    reviewed_user_id INT REFERENCES users(userid) ON DELETE CASCADE,
    rating INT CHECK (rating >= 1 AND rating <= 5),
    comment TEXT,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    CONSTRAINT cannot_review_self CHECK (reviewer_id <> reviewed_user_id),
	CONSTRAINT unique_review UNIQUE (reviewer_id, reviewed_user_id)
);
select * from reviews

CREATE TABLE user_match_requests (
    request_id SERIAL PRIMARY KEY,
    sender_id INT REFERENCES users(userid) ON DELETE CASCADE,
    receiver_id INT REFERENCES users(userid) ON DELETE CASCADE,
    status VARCHAR(20) DEFAULT 'pending'
        CHECK (status IN ('pending', 'accepted', 'rejected', 'canceled')),
    message TEXT,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,

    CONSTRAINT no_self_request CHECK (sender_id <> receiver_id)
);
select * from user_match_requests

