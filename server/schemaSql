CREATE TABLE shared_housing (
    listing_id SERIAL PRIMARY KEY,
    owner_id INT REFERENCES users(userid) ON DELETE CASCADE,
    title VARCHAR(255) NOT NULL,
    description TEXT,
    city VARCHAR(50),
    area VARCHAR(100),
	price DECIMAL(10,2) CHECK (price >= 0),
	images TEXT[],
	currency VARCHAR(10) DEFAULT 'JOD',
    is_shared BOOLEAN DEFAULT true,
    rooms_count INT CHECK (rooms_count > 0),
	bathrooms_count INT CHECK (bathrooms_count > 0),
    furnished BOOLEAN DEFAULT false,
    has_wifi BOOLEAN DEFAULT true,
    has_parking BOOLEAN DEFAULT false,
    has_kitchen BOOLEAN DEFAULT true,
    has_washing_machine BOOLEAN DEFAULT false,
    current_occupants INT DEFAULT 0,
    max_occupants INT NOT NULL,
	gender_allowed VARCHAR(10) DEFAULT 'any' CHECK (gender_allowed IN ('male', 'female', 'any')),
	latitude DECIMAL(10, 8), 
    longitude DECIMAL(11, 8),
    is_available BOOLEAN DEFAULT true,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    CONSTRAINT occupants_check CHECK (
        current_occupants >= 0 AND 
        max_occupants > 0 AND 
        current_occupants <= max_occupants
    )
	);
select * from shared_housing


CREATE TABLE roommate_requests (
    request_id SERIAL PRIMARY KEY,
    sender_id INT REFERENCES users(userid) ON DELETE CASCADE,     
    listing_id INT REFERENCES shared_housing(listing_id) ON DELETE CASCADE,
    status VARCHAR(20) DEFAULT 'pending' CHECK (status IN ('pending', 'accepted', 'rejected', 'canceled')),
    message TEXT,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
	);
select * from roommate_requests

ALTER TABLE roommate_requests
